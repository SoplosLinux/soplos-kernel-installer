msgid "DKMS modules are installed but the signing key is <b>missing</b>.\nReinstall your NVIDIA or VirtualBox drivers from soplos-welcome to regenerate it."
msgstr "DKMS modules are installed but the signing key is <b>missing</b>.\nReinstall your NVIDIA or VirtualBox drivers from soplos-welcome to regenerate it."

msgid "The DKMS signing key is enrolled. Kernel modules (NVIDIA etc.) will load correctly."
msgstr "The DKMS signing key is enrolled. Kernel modules (NVIDIA etc.) will load correctly."

msgid "The DKMS signing key is <b>not enrolled</b>. Without it, NVIDIA and other DKMS drivers will fail to load with Secure Boot enabled.\nEnroll it now alongside your kernel key."
