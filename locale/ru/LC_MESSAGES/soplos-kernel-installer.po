msgstr "Стабильная версия"

msgid "Optional patches"
msgstr "Дополнительные патчи"

msgid "No patches available"
msgstr "Патчи недоступны"

msgid "BORE"
msgstr "BORE"

msgid "Burst-Oriented Response Enhancer — improved CPU scheduler for responsiveness."
msgstr "Burst-Oriented Response Enhancer — улучшенный планировщик ЦП для отзывчивости системы."

msgid "PREEMPT_RT"
msgstr "PREEMPT_RT"

msgid "Full real-time preemption — ultra-low latency for audio/video production."
msgstr "Полное вытеснение в реальном времени — ультра-низкая задержка для аудио/видеопроизводства."

msgid "Zen"
msgstr "Zen"

msgid "Zen kernel optimizations — gaming and desktop performance."
msgstr "Оптимизации ядра Zen — производительность для игр и рабочего стола."

msgid "Applied patches: {}"
msgstr "Применённые патчи: {}"

msgid "Kernel name (suffix)"
msgstr "Имя ядра (суффикс)"

msgid "e.g.: soplos, gaming, custom"
msgstr "напр.: soplos, gaming, custom"

msgid "Combined with profile: 6.x.x-soplos-gaming"
msgstr "В сочетании с профилем: 6.x.x-soplos-gaming"

msgid "Result: {}-{}-{}"
msgstr "Результат: {}-{}-{}"

msgid "Clean build directory after installation"
msgstr "Очистить каталог сборки после установки"

msgid "Reuse existing sources"
msgstr "Повторно использовать существующие исходники"

msgid "Skip download if sources are already in ~/kernel_build"
msgstr "Пропустить загрузку, если исходники уже находятся в ~/kernel_build"

